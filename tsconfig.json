{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "rootDir": "./src",
    "outDir": "./build/js",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "sourceMap": true,
    "noEmitOnError": true,
    "incremental": true
  },
  "include": ["src"],
  "exclude": ["build", "node_modules"]
}
