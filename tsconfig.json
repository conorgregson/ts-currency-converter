{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "sourceMap": true,
    "noEmit": true,
    "incremental": true,
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": ["build", "dist", "node_modules"]
}
